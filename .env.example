# MongoDB (matches docker-compose credentials)
# authSource=admin is required: the root user is created in the `admin` db,
# so auth must be checked there even though we use the `cortex` database.
MONGODB_URL=mongodb://admin:cortex@localhost:27017/?authSource=admin
MONGODB_DB_NAME=cortex

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# App
ENVIRONMENT=local
DEBUG=true

# Google Cloud / Vertex AI (Claude + Gemini both run through Vertex)
# Auth: run `gcloud auth application-default login` — no API keys needed here.
GCP_PROJECT_ID=
VERTEX_REGION=global
ANTHROPIC_MODEL=claude-opus-4-8
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
